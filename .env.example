# ─────────────────────────────────────────────
# Verity Studio — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# On Vercel: add these in Project → Settings → Environment Variables.

# Resend API key — required for the contact form to send emails.
# Get yours free at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────
# OPTIONAL — add when you have them:
# ─────────────────────────────────────────────

# Your public Calendly URL (for the "Book a Call" button)
# NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/yourname

# Your Instagram handle (used in footer & contact section)
# NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/veritystudio
